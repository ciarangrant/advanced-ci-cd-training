# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.3.2
#
# Optional ENV vars
#   JAVA_HOME - location of a JDK home dir
#   MVNW_REPOURL - repo url base for downloading maven distributions
#   MVNW_USERNAME/MVNW_PASSWORD - user and password for downloading maven
#   MVNW_VERBOSE - true: enable verbose log; others: silence the output
# ----------------------------------------------------------------------------

set -euf
[ "${MVNW_VERBOSE-}" != true ] || set -x

# OS specific support
case "$(uname -s)" in
CYGWIN* | MINGW* | MSYS*)  native_path() { cygpath -m "$1"; } ;;
*)                          native_path() { printf %s "$1"; } ;;
esac

# set JAVA_HOME
if [ -n "${JAVA_HOME-}" ]; then
  if [ -x "$JAVA_HOME/jre/sh/java" ]; then
    JAVACMD="$JAVA_HOME/jre/sh/java"
  else
    JAVACMD="$JAVA_HOME/bin/java"
  fi
  if [ ! -x "$JAVACMD" ]; then
    echo "The JAVA_HOME environment variable is not defined correctly," >&2
    echo "this environment variable is needed to run this program." >&2
    exit 1
  fi
else
  JAVACMD="$(
    command -v java
  )" || :
  if [ ! -x "${JAVACMD-}" ]; then
    echo "The java command is not available in PATH or JAVA_HOME is not set." >&2
    exit 1
  fi
fi

# hash string like Java String.hashCode()
hash_string() {
  str="${1:-}" h=0
  while [ -n "$str" ]; do
    char="${str%"${str#?}"}"
    h=$(((h * 31 + $(LC_CTYPE=C printf %d "'$char")) % 4294967296))
    str="${str#?}"
  done
  printf %x\\n $h
}

verbose() { :; }
[ "${MVNW_VERBOSE-}" != true ] || verbose() { printf %s\\n "${@-}"; }

die() {
  printf %s\\n "$1" >&2
  exit 1
}

trim() {
  # MWRAPPER://
  printf %s\\n "${1#"${1%%[![:space:]]*}"}"
}

# parse distributionUrl and optional distributionSha256Sum, wrapperUrl, wrapperSha256Sum
while IFS="=" read -r key value; do
  case "${key-}" in
  distributionUrl) distributionUrl=$(trim "${value-}") ;;
  distributionSha256Sum) distributionSha256Sum=$(trim "${value-}") ;;
  wrapperUrl) wrapperUrl=$(trim "${value-}") ;;
  wrapperSha256Sum) wrapperSha256Sum=$(trim "${value-}") ;;
  esac
done <"${0%/*}/.mvn/wrapper/maven-wrapper.properties"

# apply MVNW_REPOURL override
case "${distributionUrl-}" in
*?-bin.zip | *?-bin.tar.gz)
  [ -z "${MVNW_REPOURL-}" ] || distributionUrl="$MVNW_REPOURL/${distributionUrl#*"apache-maven/"}"
  ;;
esac

# supply all default values
distributionUrl="${distributionUrl:-"https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.9/apache-maven-3.9.9-bin.zip"}"
distributionDir="${distributionUrl##*/}"
distributionDir="${distributionDir%%-bin.*}"

# set up Maven user home
MAVEN_USER_HOME="${MAVEN_USER_HOME:-"${HOME}/.m2"}"
MAVEN_HOME="${MAVEN_USER_HOME}/wrapper/dists/${distributionDir}-$(hash_string "$distributionUrl")"

exec_maven() {
  unset MVNW_VERBOSE MVNW_USERNAME MVNW_PASSWORD MVNW_REPOURL || :
  exec "$MAVEN_HOME/bin/mvn" "$@" || die "cannot exec maven"
}

if [ -d "$MAVEN_HOME" ]; then
  verbose "found existing Maven installation at $MAVEN_HOME"
  exec_maven "$@"
fi

case "${distributionUrl%%//*}" in
"https:" | "http:") ;;
*) die "distributionUrl is not valid, must start with https:// or http://, but got: '${distributionUrl-}'" ;;
esac

# prepare tmp dir
if TMP_DOWNLOAD_DIR="$(mktemp -d)" && [ -d "$TMP_DOWNLOAD_DIR" ]; then
  clean() { rm -rf -- "$TMP_DOWNLOAD_DIR"; }
  trap clean HUP INT TERM EXIT
else
  die "cannot create temp dir"
fi

mkdir -p -- "${MAVEN_HOME%/*}"

# Download and Install Apache Maven
verbose "Couldn't find MAVEN_HOME, downloading and installing it ..."
verbose "Downloading from: $distributionUrl"
verbose "Downloading to: $TMP_DOWNLOAD_DIR"

# Use wget or curl
if command -v wget >/dev/null; then
  verbose "Found wget ... using wget"
  QUIET="--quiet"
  [ "${MVNW_VERBOSE-}" != true ] || QUIET=""
  if [ -z "${MVNW_USERNAME-}" ] || [ -z "${MVNW_PASSWORD-}" ]; then
    wget $QUIET "$distributionUrl" -O "$TMP_DOWNLOAD_DIR/${distributionUrl##*/}" || die "failed to download $distributionUrl"
  else
    wget $QUIET --http-user="$MVNW_USERNAME" --http-password="$MVNW_PASSWORD" "$distributionUrl" -O "$TMP_DOWNLOAD_DIR/${distributionUrl##*/}" || die "failed to download $distributionUrl"
  fi
elif command -v curl >/dev/null; then
  verbose "Found curl ... using curl"
  QUIET="--silent"
  [ "${MVNW_VERBOSE-}" != true ] || QUIET=""
  if [ -z "${MVNW_USERNAME-}" ] || [ -z "${MVNW_PASSWORD-}" ]; then
    curl $QUIET -o "$TMP_DOWNLOAD_DIR/${distributionUrl##*/}" -L "$distributionUrl" || die "failed to download $distributionUrl"
  else
    curl $QUIET --user "$MVNW_USERNAME:$MVNW_PASSWORD" -o "$TMP_DOWNLOAD_DIR/${distributionUrl##*/}" -L "$distributionUrl" || die "failed to download $distributionUrl"
  fi
else
  die "Cannot find wget or curl to download Maven distribution"
fi

# If specified, validate the SHA-256 sum of the Maven distribution zip file
if [ -n "${distributionSha256Sum-}" ]; then
  distributionSha256Result=false
  if command -v sha256sum >/dev/null; then
    echo "$distributionSha256Sum  $TMP_DOWNLOAD_DIR/${distributionUrl##*/}" | sha256sum -c >/dev/null 2>&1 && distributionSha256Result=true
  elif command -v shasum >/dev/null; then
    echo "$distributionSha256Sum  $TMP_DOWNLOAD_DIR/${distributionUrl##*/}" | shasum -a 256 -c >/dev/null 2>&1 && distributionSha256Result=true
  else
    echo "Checksum validation was requested but neither 'sha256sum' or 'shasum' are available." >&2
  fi
  if [ $distributionSha256Result = false ]; then
    die "SHA-256 checksum validation failed for $distributionUrl"
  fi
fi

# unzip and move
if command -v unzip >/dev/null; then
  unzip -o -q "$TMP_DOWNLOAD_DIR/${distributionUrl##*/}" -d "$TMP_DOWNLOAD_DIR" || die "failed to unzip"
else
  tar xzf "$TMP_DOWNLOAD_DIR/${distributionUrl##*/}" -C "$TMP_DOWNLOAD_DIR" || die "failed to untar"
fi
printf %s\\n "$TMP_DOWNLOAD_DIR"/*maven*
mv -- "$TMP_DOWNLOAD_DIR"/*maven*/ "$MAVEN_HOME" || die "failed to move Maven"
verbose "Maven installed at $MAVEN_HOME"

exec_maven "$@"
